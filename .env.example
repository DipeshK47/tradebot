# Copy to .env (chmod 600) ON THE VPS. Never commit .env. Never paste secrets in chat.

# --- Upstox API (current data source — the whole API is free) ---
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=http://127.0.0.1:8000/auth/upstox/callback   # register this EXACT value in your Upstox app
UPSTOX_ACCESS_TOKEN=          # auto-filled by the "Login with Upstox" button (expires 3:30 AM IST)

# --- Dhan API (possible execution broker for later; its data API is paid) ---
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# --- Telegram (control channel) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=     # your numeric Telegram id — the ONLY id allowed to command
TELEGRAM_WEBHOOK_SECRET=

# --- LLM slow-brain (optional until the news phase) ---
ANTHROPIC_API_KEY=

# --- Database ---
DATABASE_URL=postgresql://localhost:5432/tradingbot

# --- Dashboard remote access (only needed to open it from ANOTHER machine) ---
# Leave blank for local-only use. To expose on your LAN or via a tunnel, set BOTH a
# password (required) and HOST=0.0.0.0. The dashboard then demands this login.
DASHBOARD_USER=admin
DASHBOARD_PASS=               # set a strong password to expose the dashboard
# HOST=0.0.0.0                # uncomment to bind all interfaces (LAN/tunnel); needs DASHBOARD_PASS

# --- Mode ---
TRADING_MODE=paper            # paper | live  (live ALSO requires arming in the dashboard)
